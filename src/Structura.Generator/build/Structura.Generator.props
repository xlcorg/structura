<Project>

  <!--
    Convention for Structura sample documents (JSON and XML).

    A consuming project sets:

      <PropertyGroup>
        <StructuraJsonSamplesFolder>Samples</StructuraJsonSamplesFolder>
      </PropertyGroup>

    and imports this file. Every *.json and *.xml file in that folder is then
    exposed to the source generators as an AdditionalFile, and each generator
    produces a strongly-typed model class per file in the Structura.Generated
    namespace.

    The property name retains the historical "Json" infix for backwards
    compatibility — it now governs both JSON and XML inputs.

    Default folder: Samples (relative to the consuming project directory).
  -->
  <PropertyGroup>
    <StructuraJsonSamplesFolder Condition="'$(StructuraJsonSamplesFolder)' == ''">Samples</StructuraJsonSamplesFolder>
  </PropertyGroup>

  <ItemGroup Condition="Exists('$(MSBuildProjectDirectory)\$(StructuraJsonSamplesFolder)')">
    <AdditionalFiles Include="$(StructuraJsonSamplesFolder)\*.json" />
    <AdditionalFiles Include="$(StructuraJsonSamplesFolder)\*.xml" />
  </ItemGroup>

</Project>
